/* ============================================= */
const D = window.REPORT_DATA;
const S = D.summary;
const fmt = n => n.toLocaleString('en-US');
const css = v => getComputedStyle(document.documentElement).getPropertyValue(v).trim();

/* meta */
document.getElementById('meta').innerHTML =
  `<span><b>Window</b> Jul 2025 – May 2026</span>`+
  `<span><b>Reports</b> ${S.months} monthly exports</span>`+
  `<span><b>Rows</b> ${fmt(S.total_rows)}</span>`+
  `<span><b>Distinct players</b> ${fmt(S.distinct_players)}</span>`;

/* finding */
document.getElementById('finding-text').innerHTML =
  `The May 2026 export added <b>${fmt(S.na_players)}</b> player records with no source attribution, every one `+
  `stamped with the same registration date (<span class="mono warn-date">${S.migration_date}</span>) and carrying `+
  `<b>zero</b> financial value. <b>${S.na_pct_recoverable}%</b> of them are not new players at all — they match `+
  `existing players from earlier reports. This migration also created <b>${fmt(S.dup_players)}</b> players that now `+
  `carry conflicting registration dates across the reporting history.`;

/* cards */
const cards=[
  {k:'Distinct players',v:fmt(S.distinct_players),d:'across all 11 reports, by core ID'},
  {k:'N/A players (no source)',v:fmt(S.na_players),d:'all dated '+S.migration_date,cls:'alert'},
  {k:'Recoverable attribution',v:S.na_pct_recoverable+'%',d:'of N/A players match prior history',cls:'good'},
  {k:'Conflicting reg. dates',v:fmt(S.dup_players),d:'players with >1 registration date',cls:'bad'},
  {k:'Traceable to a named sub-ID',v:fmt(S.na_recoverable_named),d:'N/A players → real sub-ID'},
  {k:'Generic-only at source',v:fmt(S.na_generic_only),d:'were already unattributed'},
  {k:'Genuinely unknown',v:fmt(S.na_unknown),d:'no history anywhere',cls:'bad'},
  {k:'Financial value of N/A rows',v:'R'+S.na_financial_value,d:'no money double-counted',cls:'good'},
];
document.getElementById('cards').innerHTML=cards.map(c=>
  `<div class="card ${c.cls||''}"><div class="k">${c.k}</div><div class="v">${c.v}</div><div class="d">${c.d}</div></div>`).join('');

/* anatomy list */
document.getElementById('anatomy').innerHTML=[
  `<b>${fmt(S.na_players)}</b> records appeared under the new <code style="font-family:var(--mono)">RSA_&lt;id&gt;</code> format.`,
  `All <b>${fmt(S.na_players)}</b> share one registration date: <span class="mono warn-date">${S.migration_date}</span>.`,
  `<b>${fmt(S.may_intra_dupes)}</b> of them duplicate a player already present in the very same May file under the normal numeric ID.`,
  `Every <code style="font-family:var(--mono)">RSA_</code> row reports R0 deposits, R0 stakes and R0 commission.`,
  `Conclusion: these are migration copies, not <b>${fmt(S.na_players)}</b> new signups.`
].map(t=>`<li>${t}</li>`).join('');


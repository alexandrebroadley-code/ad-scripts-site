  type:'doughnut',
  data:{labels:['Traceable to named sub-ID','Generic (already unattributed)','Unknown — no history'],
    datasets:[{data:[named,gen,unk],backgroundColor:[css('--info'),css('--mute'),css('--bad')],borderColor:css('--panel'),borderWidth:3}]},
  options:{maintainAspectRatio:false,cutout:'62%',
    plugins:{legend:{position:'bottom',labels:{color:css('--soft'),font:{size:12},boxWidth:12,padding:14}}}}
});

/* attribution list (named only, exclude Generic/Unknown) */
const skip=new Set(['generic','unknown (no history)']);
const named_rows=D.na_breakdown.filter(r=>!skip.has(r.source.toLowerCase()));
const maxN=Math.max(...named_rows.map(r=>r.players));
document.getElementById('attrList').innerHTML=named_rows.slice(0,40).map(r=>
  `<div class="attr-row"><span class="nm">${r.source}</span>`+
  `<span class="bar"><i style="width:${(r.players/maxN*100).toFixed(1)}%"></i></span>`+
  `<span class="ct">${fmt(r.players)}</span></div>`).join('');

/* ===== duplicates table ===== */
const cols=D.dup_cols, raw=D.dup_rows; // [core_id, dates, periods, sources, rsa]
let rows=raw.map(r=>({core_id:r[0],dates:r[1],ndates:r[1].split('|').length,periods:r[2],sources:r[3],rsa:r[4]}));
let fRsa=false,fNamed=false,sortK='ndates',sortDir=-1,query='';
const namedRe=/za|ng|rza|rng/i;

function srcTags(s){
  if(s==='(none)') return '<span class="tag gen">(none)</span>';
  return s.split('|').map(x=>{
    const lc=x.toLowerCase();
    const cls = lc==='generic'?'tag gen':'tag';
    return `<span class="${cls}">${x}</span>`;
  }).join('');
}
function datesCell(s){
  return s.split('|').map(d=>d===S.migration_date?`<span class="mono warn-date">${d}</span>`:`<span class="mono">${d}</span>`).join('  ');
}
function render(){
  let r=rows.filter(x=>{
    if(fRsa && !x.rsa) return false;
    if(fNamed && !namedRe.test(x.sources)) return false;
    if(query){
      const q=query.toLowerCase();
      if(!(x.core_id.toLowerCase().includes(q)||x.sources.toLowerCase().includes(q))) return false;
    }
    return true;
  });
  r.sort((a,b)=>{
    let av=a[sortK],bv=b[sortK];
    if(typeof av==='string'){av=av.toLowerCase();bv=bv.toLowerCase();}
    return av<bv?-sortDir:av>bv?sortDir:0;
  });
  document.getElementById('dupCount').textContent=fmt(r.length)+' of '+fmt(rows.length)+' players';
  const show=r.slice(0,400);
  document.getElementById('dupShown').textContent=fmt(show.length);
  document.getElementById('dupBody').innerHTML=show.map(x=>
    `<tr><td class="mono">${x.rsa?'<span class="tag rsa">RSA</span> ':''}${x.core_id}</td>`+
    `<td class="mono" style="text-align:center">${x.ndates}</td>`+
    `<td>${datesCell(x.dates)}</td>`+
    `<td class="mono" style="text-align:center">${x.periods}</td>`+
    `<td>${srcTags(x.sources)}</td></tr>`).join('');
}
document.getElementById('dupSearch').addEventListener('input',e=>{query=e.target.value.trim();render();});
document.getElementById('fRsa').addEventListener('click',e=>{fRsa=!fRsa;e.target.setAttribute('aria-pressed',fRsa);render();});
document.getElementById('fNamed').addEventListener('click',e=>{fNamed=!fNamed;e.target.setAttribute('aria-pressed',fNamed);render();});
document.querySelectorAll('thead th').forEach(th=>th.addEventListener('click',()=>{
  const k=th.dataset.k; if(k==='dates')return;
  if(sortK===k)sortDir*=-1; else{sortK=k;sortDir=-1;} render();
}));
render();
